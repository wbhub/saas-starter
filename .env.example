NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_MICROSOFT_ENABLED=false
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=sk-proj-xxx
# AI access mode:
# - paid (default): existing behavior; requires eligible paid subscription + plan model map.
# - all: any authenticated user can access AI using AI_DEFAULT_MODEL and AI_DEFAULT_MONTHLY_TOKEN_BUDGET.
# - by_plan: policy comes from AI_PLAN_RULES_JSON for free|starter|growth|pro.
AI_ACCESS_MODE=paid
# Default model used by AI_ACCESS_MODE=all (and optional paid fallback, if you choose to wire one).
AI_DEFAULT_MODEL=
# Default monthly team budget used by AI_ACCESS_MODE=all. 0 disables budget claim/finalize.
AI_DEFAULT_MONTHLY_TOKEN_BUDGET=0
# JSON object for AI_ACCESS_MODE=by_plan.
# Keys: free|starter|growth|pro
# Values: { enabled: boolean, model: string|null, monthlyBudget: number }
# Example:
# AI_PLAN_RULES_JSON={"free":{"enabled":false,"model":null,"monthlyBudget":0},"starter":{"enabled":true,"model":"gpt-4.1-mini","monthlyBudget":500000},"growth":{"enabled":true,"model":"gpt-4.1","monthlyBudget":2000000},"pro":{"enabled":true,"model":"gpt-4.1","monthlyBudget":5000000}}
AI_PLAN_RULES_JSON=
# Comma-separated Stripe subscription statuses that can access AI.
# Must be values from Stripe status set (e.g. trialing,active,past_due).
AI_ALLOWED_SUBSCRIPTION_STATUSES=
# JSON object: plan key -> OpenAI model. Set value to null to disable AI for that plan.
AI_PLAN_MODEL_MAP_JSON={"starter":null,"growth":null,"pro":null}
# JSON object: plan key -> monthly team token budget.
AI_PLAN_MONTHLY_TOKEN_BUDGET_MAP_JSON={"starter":0,"growth":0,"pro":0}
# App-level free tier toggle (not a Stripe product/price).
# When true, teams with no live paid Stripe subscription resolve to "Free".
APP_FREE_PLAN_ENABLED=false
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_starter_xxx
STRIPE_GROWTH_PRICE_ID=price_growth_xxx
STRIPE_PRO_PRICE_ID=price_pro_xxx
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=SaaS Starter <onboarding@resend.dev>
RESEND_SUPPORT_EMAIL=support@yourdomain.com
NEXT_PUBLIC_INTERCOM_APP_ID=
INTERCOM_IDENTITY_SECRET=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_ENVIRONMENT=
STRIPE_SEAT_PRORATION_BEHAVIOR=create_prorations
TEAM_MAX_MEMBERS=100
TRUST_PROXY_HEADERS=false
# Enable only behind a trusted proxy that strips/overwrites forwarding headers.
# Optional comma-separated override for trusted IP headers.
# Example: TRUSTED_PROXY_HEADER_NAMES=x-forwarded-for,cf-connecting-ip
TRUSTED_PROXY_HEADER_NAMES=
# Optional: protects GET /api/cron/prune-stripe-webhook-events (scheduled dedupe row cleanup).
# Send as Authorization: Bearer <CRON_SECRET> — do not put the secret in the URL.
CRON_SECRET=
