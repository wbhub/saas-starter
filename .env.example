# Quick start:
# 1) Copy this file to .env.local
# 2) Fill the REQUIRED TO BOOT section first
# 3) Configure OPTIONAL/CONDITIONAL sections for enabled features

# ===== REQUIRED TO BOOT =====
# Core app + Supabase (minimum needed to run locally)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-secret-key

# ===== OPTIONAL: AUTH PROVIDERS (UI TOGGLES) =====
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_MICROSOFT_ENABLED=false

# ===== OPTIONAL: AI PROVIDER + ACCESS POLICY =====
# AI provider:
# - openai (default): uses OpenAI directly
# - anthropic: uses Anthropic models (Claude)
# - google: uses Google Generative AI models (Gemini)
AI_PROVIDER=openai
# Preferred provider API key (works for openai, anthropic, and google).
# If unset, provider-specific fallbacks are used.
AI_PROVIDER_API_KEY=
# Provider-specific key fallbacks:
OPENAI_API_KEY=sk-proj-xxx
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# AI access mode:
# - paid (default): existing behavior; requires eligible paid subscription + plan model map.
# - all: any authenticated user can access AI using AI_DEFAULT_MODEL and AI_DEFAULT_MONTHLY_TOKEN_BUDGET.
# - by_plan: policy comes from AI_PLAN_RULES_JSON for free|starter|growth|pro.
AI_ACCESS_MODE=paid
# Default model used by AI_ACCESS_MODE=all (and optional paid fallback, if you choose to wire one).
AI_DEFAULT_MODEL=
# Default monthly team budget used by AI_ACCESS_MODE=all. 0 disables budget claim/finalize.
AI_DEFAULT_MONTHLY_TOKEN_BUDGET=0
# Comma-separated allowed modalities for AI requests.
# Supported values: text,image,file
# Defaults to text-only when unset/invalid.
AI_ALLOWED_MODALITIES=text
# Optional JSON object: model key -> allowed modalities.
# Keys can be exact model IDs or prefix wildcards ending with *.
# Keys can be provider-scoped using "<provider>:<model-or-prefix>".
# Example:
# AI_MODEL_MODALITIES_MAP_JSON={"openai:gpt-4.1*":["text","image","file"],"anthropic:claude*":["text","image","file"],"google:gemini*":["text","image","file"],"gpt-3.5*":["text"]}
AI_MODEL_MODALITIES_MAP_JSON=
# JSON object for AI_ACCESS_MODE=by_plan.
# Keys: free|starter|growth|pro
# Values: { enabled: boolean, model: string|null, monthlyBudget: number, allowedModalities?: ("text"|"image"|"file")[] }
# Example:
# AI_PLAN_RULES_JSON={"free":{"enabled":false,"model":null,"monthlyBudget":0,"allowedModalities":["text"]},"starter":{"enabled":true,"model":"gpt-4.1-mini","monthlyBudget":500000,"allowedModalities":["text","image"]},"growth":{"enabled":true,"model":"gpt-4.1","monthlyBudget":2000000,"allowedModalities":["text","image","file"]},"pro":{"enabled":true,"model":"gpt-4.1","monthlyBudget":5000000,"allowedModalities":["text","image","file"]}}
AI_PLAN_RULES_JSON=
# Comma-separated Stripe subscription statuses that can access AI.
# Must be values from Stripe status set (e.g. trialing,active,past_due).
AI_ALLOWED_SUBSCRIPTION_STATUSES=
# JSON object: plan key -> model id string. Set value to null to disable AI for that plan.
AI_PLAN_MODEL_MAP_JSON={"starter":null,"growth":null,"pro":null}
# JSON object: plan key -> monthly team token budget.
AI_PLAN_MONTHLY_TOKEN_BUDGET_MAP_JSON={"starter":0,"growth":0,"pro":0}
# Optional JSON object: plan key -> allowed modalities.
# Used by AI_ACCESS_MODE=paid. Missing/invalid entries default to text-only.
# Example:
# AI_PLAN_MODALITIES_MAP_JSON={"starter":["text","image"],"growth":["text","image","file"],"pro":["text","image","file"]}
AI_PLAN_MODALITIES_MAP_JSON=
# AI agent / tool-calling support (opt-in).
# When false (default), single-turn chat with no tools — existing behavior.
AI_TOOLS_ENABLED=false
NEXT_PUBLIC_AI_TOOLS_ENABLED=false
# Max model steps per request (default 5).
# Higher values enable multi-step agent loops when tools are enabled.
# In by_plan mode, can be overridden per plan via AI_PLAN_RULES_JSON "maxSteps".
AI_MAX_STEPS=5
# Optional tool integrations (each enabled when its API key is set).
# E2B code interpreter: isolated code execution in a cloud sandbox.
E2B_API_KEY=
# Tavily: web search.
TAVILY_API_KEY=
# Firecrawl: page scraping.
FIRECRAWL_API_KEY=
# Composio: third-party actions.
COMPOSIO_API_KEY=

# ===== OPTIONAL: BILLING + PLANS =====
# App-level free tier toggle (not a Stripe product/price).
# When true, teams with no live paid Stripe subscription resolve to "Free".
APP_FREE_PLAN_ENABLED=true
# Billing provider switch:
# - none (default): free-only mode, Stripe billing routes disabled.
# - stripe: enable paid billing and require Stripe env vars below.
BILLING_PROVIDER=none
STRIPE_SEAT_PRORATION_BEHAVIOR=create_prorations
TEAM_MAX_MEMBERS=100

# ===== OPTIONAL: STRIPE =====
# Optional: enable paid billing with Stripe.
# Requires BILLING_PROVIDER=stripe.
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_starter_xxx
STRIPE_GROWTH_PRICE_ID=price_growth_xxx
STRIPE_PRO_PRICE_ID=price_pro_xxx
# Optional: annual price IDs for monthly/annual billing toggle (20% discount).
# If unset, only monthly billing is shown.
# STRIPE_STARTER_ANNUAL_PRICE_ID=price_starter_annual_xxx
# STRIPE_GROWTH_ANNUAL_PRICE_ID=price_growth_annual_xxx
# STRIPE_PRO_ANNUAL_PRICE_ID=price_pro_annual_xxx

# ===== CONDITIONAL: EMAIL (RESEND) =====
# Required for full support email + custom invite/reset email flows.
# If unset:
# - forgot-password falls back to Supabase-managed delivery
# - support email endpoint returns feature-disabled (503)
# - team invite create/resend still succeeds with emailSent=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_SUPPORT_EMAIL=

# ===== OPTIONAL: BACKGROUND JOBS (TRIGGER.DEV) =====
# Optional: Trigger.dev v3 background jobs.
# If TRIGGER_SECRET_KEY is unset, all jobs run inline exactly as before.
TRIGGER_SECRET_KEY=
# Required only for Trigger.dev deploy/CLI workflows.
TRIGGER_PROJECT_REF=

# ===== OPTIONAL: CUSTOMER MESSAGING (INTERCOM) =====
NEXT_PUBLIC_INTERCOM_APP_ID=
INTERCOM_IDENTITY_SECRET=

# ===== OPTIONAL: ERROR MONITORING (SENTRY) =====
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_ENVIRONMENT=

# ===== OPTIONAL: CACHING (UPSTASH REDIS) =====
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== OPTIONAL: NETWORK + SECURITY =====
TRUST_PROXY_HEADERS=false
# Enable only behind a trusted proxy that strips/overwrites forwarding headers.
# Optional comma-separated override for trusted IP headers.
# Example: TRUSTED_PROXY_HEADER_NAMES=x-forwarded-for,cf-connecting-ip
TRUSTED_PROXY_HEADER_NAMES=
# Optional: protects GET /api/cron/prune-stripe-webhook-events (scheduled dedupe row cleanup).
# Send as Authorization: Bearer <CRON_SECRET> — do not put the secret in the URL.
CRON_SECRET=
