{
  "name": "saas-starter",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:locales": "tsx scripts/check-locales.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e": "playwright test --project=full",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:conventions": "tsx scripts/check-env-usage.ts && tsx scripts/check-response-helpers.ts && tsx scripts/check-route-wrappers.ts && tsx scripts/check-locales.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.31",
    "@ai-sdk/google": "^2.0.25",
    "@ai-sdk/openai": "^3.0.47",
    "@ai-sdk/react": "^3.0.136",
    "@base-ui/react": "^1.3.0",
    "@e2b/code-interpreter": "^2.4.0",
    "@sentry/nextjs": "^10.45.0",
    "@stripe/stripe-js": "^8.10.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@trigger.dev/sdk": "4.4.0",
    "@upstash/redis": "^1.37.0",
    "ai": "^6.0.134",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-intl": "^4.8.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "server-only": "0.0.1",
    "shadcn": "^4.1.1",
    "stripe": "^20.4.1",
    "sugar-high": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
